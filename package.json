{
  "name": "sakinah-now-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "extension:build": "node extension/scripts/build.mjs",
    "extension:watch": "node --watch extension/scripts/build.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run typecheck && pnpm run lint",
    "reflections:fetch": "node scripts/quran-reflect-fetch.mjs",
    "reflections:generate": "node scripts/quran-reflect-generate-all.mjs",
    "reflections:stats": "node scripts/quran-reflect-stats.mjs"
  },
  "dependencies": {
    "@quranjs/api": "^2.2.0",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/node": "^4.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tailwind-canonical-classes": "^1.3.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
